{
  "AppName": "POS Retail API",
  "AppVersion": "1.0.0",
  "AppPort": "8080",
  "Timezone": "Asia/Jakarta",
  "ReleaseMode": "release",

  "SecretKey": "pos-retail-secret-key-prod-CHANGE-ME",
  "TokenExpire": 28800,
  "RefreshTokenExpire": 604800,

  "Database": {
    "Type": "mysql",
    "Host": "127.0.0.1",
    "Port": "3306",
    "User": "pos_user",
    "Password": "",
    "Database": "pos_retail_db",
    "MaxOpenConns": 50,
    "MaxIdleConns": 10,
    "MaxLifetime": 300
  },

  "CorsAllowOrigins": [
    "https://pos.example.com"
  ],

  "LogPath": "logs",
  "MaxLogAge": 30
}
